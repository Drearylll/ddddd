# Vercel 忽略文件配置
# 这些文件不会被 Vercel 构建系统处理

# ====================
# 文档和 Markdown 文件
# ====================
docs/
*.md

# ====================
# 测试文件
# ====================
tests/
dev/

# ====================
# 数据库和数据文件（Serverless 不支持）
# ====================
*.db
data/
user_data/

# ====================
# 缓存和临时文件
# ====================
__pycache__/
*.pyc
*.pyo
.env
.env.local
*.log

# ====================
# IDE 配置
# ====================
.vscode/
.idea/
.lingma/
.cursor/
*.swp
*.swo
*~

# ====================
# Git
# ====================
.git/
.gitignore

# ====================
# 本地工具脚本（不需要部署）
# ====================
Procfile
deploy.bat
verify_project.py
清除头像数据.js

# ====================
# 其他开发文件
# ====================
*.tmp
*.bak
instance/
.webassets-cache
